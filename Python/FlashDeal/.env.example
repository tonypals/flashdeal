# ── Supabase ──────────────────────────────────────────────────────────────────
# Hitta i Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generera med: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=generera-en-lång-slumpmässig-sträng-här

# ── Admin-PIN ─────────────────────────────────────────────────────────────────
# PIN-kod för att logga in på plattformsadmin (/admin)
ADMIN_PIN=123456

# ── Bas-URL (din domän i produktion, localhost lokalt) ────────────────────────
BASE_URL=http://localhost:5000

# ── Mail via Gmail ────────────────────────────────────────────────────────────
# Alternativ 1: Gmail OAuth (rekommenderat för produktion)
# Kör credentials/get_credentials.py en gång, konvertera token.json till sträng:
# python -c "import json; print(json.dumps(json.load(open('credentials/token.json'))))"
GOOGLE_CREDENTIALS=

# Alternativ 2: Gmail SMTP med app-lösenord (enklast för test)
# Aktivera "App passwords" i Google-kontot (behöver 2FA aktiverat)
# Gå till myaccount.google.com → Security → App passwords
GMAIL_USER=ditt.konto@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── SMS via 46elks ────────────────────────────────────────────────────────────
# Skapa konto på 46elks.com → API credentials
ELKS_USERNAME=
ELKS_PASSWORD=
# Avsändarnamn (registreras hos 46elks, tar 1-2 dagar)
ELKS_FROM=FlashDeal

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# Stripe Dashboard → Developers → Webhooks → Add endpoint → /betala/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Stripe platform fee i procent (6 = 6%)
STRIPE_PLATFORM_FEE_PCT=6
